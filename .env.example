# ─────────────────────────────────────────────
#  EduHelper — Environment Variables Template
#  Copy this file to .env and fill in your values
#  NEVER commit the actual .env file to git
# ─────────────────────────────────────────────

# ── MongoDB ───────────────────────────────────
# When running via Docker (recommended), leave this as-is.
# 'db' is the Docker service name for MongoDB.
MONGODB_URL=mongodb://db:27017
DATABASE_NAME=ai_university_advisor

# ── OpenAI API ────────────────────────────────
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Security ──────────────────────────────────
# Generate a strong random secret key for JWT tokens.
# You can generate one with: openssl rand -hex 32
JWT_SECRET_KEY=your_strong_random_secret_key_here

# ── Frontend (Vite) ───────────────────────────
# This tells the React app where the backend API is.
# Keep this value as-is when using Docker.
VITE_API_URL=http://localhost:8000/api/v1
